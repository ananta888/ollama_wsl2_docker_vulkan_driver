{
  "commands": {
    "timeout_seconds": 10,
    "long_timeout_seconds": 30
  },
  "ollama": {
    "base_url": "http://127.0.0.1:11434",
    "timeout_seconds": 3
  },
  "docker": {
    "smoke_test_image": "hello-world",
    "allow_image_pull": false,
    "run_smoke_test": true,
    "runtime_image": "ollama-wsl-amd:latest",
    "container_name": "ollama-env-audit",
    "published_port": 11434,
    "model_cache_volume": "ollama-env-audit-model-cache",
    "mount_wsl_lib_directory": true,
    "wsl_lib_directory": "/usr/lib/wsl",
    "ld_library_path": "/usr/lib/wsl/lib:/usr/local/nvidia/lib:/usr/local/nvidia/lib64",
    "enable_ollama_vulkan": true,
    "force_dozen_icd": true,
    "dozen_icd_path": "/usr/share/vulkan/icd.d/dzn_icd.json",
    "mesa_d3d12_default_adapter_name": "AMD Radeon(TM) 780M"
  },
  "benchmark": {
    "default_model": "llama3.2:3b",
    "prompt": "Summarize the current machine in one sentence.",
    "request_timeout_seconds": 90,
    "num_predict": 64
  },
  "runtime": {
    "windows_base_url": "http://127.0.0.1:11434",
    "wsl_base_url": "http://127.0.0.1:11434",
    "docker_base_url": "http://127.0.0.1:11434"
  },
  "web": {
    "host": "127.0.0.1",
    "port": 8765
  }
}
